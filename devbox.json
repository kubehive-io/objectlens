{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.17.5/.schema/devbox.schema.json",
  "packages": [
    "uv",
    "nodejs_22",
    "just",
    "git",
    "jq",
    "curl",
    "python312Packages.mkdocs-material",
    "docker",
    "kubectl",
    "kubernetes-helm",
    "k9s",
    "python312@latest",
    "mkdocs@latest"
  ],
  "shell": {
    "init_hook": [
      "echo 'ObjectLens devbox ready. Run: just install && just dev'"
    ],
    "scripts": {
      "install":    "just install",
      "backend":    "just backend",
      "frontend":   "just frontend",
      "dev":        "just dev",
      "docs":       "just docs",
      "docs-build": "just docs-build",
      "lint":       "just lint",
      "format":     "just format",
      "test":       "just test"
    }
  }
}
