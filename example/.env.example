NUXT_PUBLIC_API_BASE_URL=http://localhost:8000

OBJECTLENS_APP_NAME=ObjectLens
OBJECTLENS_PROVIDER=ceph
OBJECTLENS_PROVIDERS_CONFIG=.objectlens.providers.yaml
OBJECTLENS_CORS_ORIGINS=http://localhost:3000
OBJECTLENS_DATABASE_URL=sqlite:///./objectlens.db

# Preferred multi-provider setup:
# 1. cp example/.objectlens.providers.example.yaml .objectlens.providers.yaml
# 2. Put real secrets in your local shell, .env, or secret manager.
# 3. Reference them from YAML with ${ENV_VAR}.
AWS_PROD_ACCESS_KEY_ID=
AWS_PROD_SECRET_ACCESS_KEY=
AWS_BACKUP_ACCESS_KEY_ID=
AWS_BACKUP_SECRET_ACCESS_KEY=
CEPH_HOMELAB_ACCESS_KEY_ID=
CEPH_HOMELAB_SECRET_ACCESS_KEY=
GARAGE_LOCAL_ACCESS_KEY_ID=
GARAGE_LOCAL_SECRET_ACCESS_KEY=

# Ceph RGW / S3-compatible object storage.
# Legacy single-provider fallback. Prefer .objectlens.providers.yaml for multiple connections.
CEPH_S3_ENDPOINT_URL=http://localhost:9000
CEPH_S3_REGION=us-east-1
CEPH_S3_ACCESS_KEY_ID=minioadmin
CEPH_S3_SECRET_ACCESS_KEY=minioadmin
CEPH_S3_DEFAULT_BUCKET=objectlens-demo
CEPH_S3_VERIFY_SSL=false

# Garage / S3-compatible object storage.
GARAGE_S3_ENDPOINT_URL=http://localhost:3900
GARAGE_S3_REGION=garage
GARAGE_S3_ACCESS_KEY_ID=garage
GARAGE_S3_SECRET_ACCESS_KEY=garage
GARAGE_S3_DEFAULT_BUCKET=
GARAGE_S3_VERIFY_SSL=false
